<?xml version="1.0"?>
<ruleset name="Apex Cast">
	<description>PHP_CodeSniffer rules for Apex Cast for WooCommerce.</description>

	<!-- Files to scan. Test files follow PHPUnit conventions and are excluded;
	     PHPUnit itself validates them. -->
	<file>apex-cast.php</file>
	<file>includes/</file>

	<!-- Exclusions -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/assets/build/*</exclude-pattern>
	<exclude-pattern>*/tests/coverage/*</exclude-pattern>

	<!-- Scan only PHP -->
	<arg name="extensions" value="php"/>

	<!-- Run with colors and progress -->
	<arg name="colors"/>
	<arg value="ps"/>

	<!-- Use a parallel scan -->
	<arg name="parallel" value="8"/>

	<!-- Use cache for faster repeat runs -->
	<arg name="cache" value=".phpcs-cache"/>

	<!-- WordPress Coding Standards -->
	<rule ref="WordPress">
		<!-- Classes load via a Composer classmap, so the acronym-sensitive
		     filename sniff (e.g. AIProviderException) adds friction with no benefit. -->
		<exclude name="WordPress.Files.FileName"/>

		<!-- The only capability this plugin checks is WooCommerce's manage_woocommerce;
		     the sniff doesn't know about WC-provided caps. -->
		<exclude name="WordPress.WP.Capabilities"/>

		<!-- Exception messages travel through REST JSON envelopes, never echoed as HTML.
		     The sniff demands escaping at the throw site, which would be wrong here. -->
		<exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
	</rule>
	<rule ref="WordPress-Extra">
		<exclude name="WordPress.WP.Capabilities"/>
		<exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
	</rule>

	<!-- Text domain enforcement -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="apex-cast"/>
			</property>
		</properties>
	</rule>

	<!-- PHP version compatibility -->
	<config name="testVersion" value="8.1-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- Minimum WP version supported -->
	<config name="minimum_supported_wp_version" value="6.0"/>
</ruleset>
